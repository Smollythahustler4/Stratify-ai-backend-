PORT=3000
NODE_ENV=development

# Generate this key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your_secret_api_key_here

# Your Lovable app URL
ALLOWED_ORIGIN=https://your-app.lovable.app

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

MAX_FILE_SIZE_MB=10
FILE_TTL_MS=3600000

# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Get from https://sentry.io
SENTRY_DSN=

LOG_LEVEL=dev
